{{! Latest Updates Section - Using Ghost Posts }}
<section class="bg-lp-light-blue py-8 sm:py-12 md:py-16 lg:py-20">
    <div class="container mx-auto px-4 sm:px-6">
        <div class="max-w-[857px] mx-auto">
        <h2 class="text-[28px] sm:text-[32px] md:text-[40px] font-bold mb-3 sm:mb-4 text-center leading-[120%] sm:leading-[130%] md:leading-[52px] px-2">
            Latest Updates
        </h2>
        <p class="text-[16px] sm:text-[18px] md:text-[20px] font-medium text-center mb-8 sm:mb-10 md:mb-12 max-w-3xl mx-auto leading-[24px] sm:leading-[26px] md:leading-[28px] px-2">
            Our team is constantly listening to stations and end users to improve Local Public.
        </p>
        </div>
        <div class="grid sm:grid-cols-2 md:grid-cols-3 gap-6 sm:gap-8 max-w-6xl mx-auto">
            {{#get "posts" limit="3" include="tags,authors"}}
                {{#foreach posts}}
                    {{> "card"}}
                {{/foreach}}
            {{else}}
                {{! Fallback content if no posts }}
                <div class="bg-white rounded-lg overflow-hidden shadow-sm hover:shadow-md transition-shadow">
                    <div class="bg-gradient-to-br from-lp-dark-blue to-lp-light-blue h-48 sm:h-56 flex items-center justify-center">
                        <span class="text-white text-4xl font-bold">L</span>
                    </div>
                    <div class="p-4 sm:p-6">
                        <h3 class="text-lg sm:text-xl md:text-2xl font-bold text-lp-dark-blue">Local Public comes to the web</h3>
                    </div>
                </div>
            {{/get}}
        </div>
    </div>
</section>

