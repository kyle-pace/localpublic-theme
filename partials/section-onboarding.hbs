{{! Fast Onboarding Section }}
{{#get "pages" limit="1" filter="tag:hash-fast-onboarding"}}
    {{#foreach pages}}  
<section class="bg-lp-light-blue py-8 sm:py-12 md:py-16">
    <div class="container mx-auto px-4 sm:px-6">
        <h2 class="text-[28px] sm:text-[32px] md:text-[40px] font-bold mb-3 sm:mb-4 text-center leading-[120%] sm:leading-[130%] md:leading-[52px] px-2">
            {{title}}
        </h2>
        <p class="text-[16px] sm:text-[18px] md:text-[20px] font-medium text-center mb-8 sm:mb-10 md:mb-12 leading-[24px] sm:leading-[26px] md:leading-[28px] px-2">
            {{excerpt}}
        </p>
        <div class="grid sm:grid-cols-2 md:grid-cols-3 gap-4 sm:gap-6 md:gap-8 lg:gap-[50px] max-w-[1040px] mx-auto justify-items-center md:justify-items-start">
            {{content}}
            <div class="text-center hidden">
                <div class="text-4xl sm:text-5xl md:text-6xl lg:text-[80px] leading-none font-extrabold italic text-lp-dark-blue mb-2 sm:mb-3 md:mb-2 text-center md:text-left">6</div>
                <p class="text-xs sm:text-sm md:text-base text-lp-gray px-0 text-left">weeks from signature to app store</p>
            </div>
            <div class="text-center hidden">
                <div class="text-4xl sm:text-5xl md:text-6xl lg:text-[80px] leading-none font-extrabold italic text-lp-dark-blue mb-2 sm:mb-3 md:mb-2 text-center md:text-left">10</div>
                <p class="text-xs sm:text-sm md:text-base text-lp-gray px-0 text-left">OTT, smart TV, mobile, and web platforms.</p>
            </div>
            <div class="text-center sm:col-span-2 md:col-span-1 hidden">
                <div class="text-4xl sm:text-5xl md:text-6xl lg:text-[80px] leading-none font-extrabold italic text-lp-dark-blue mb-2 sm:mb-3 md:mb-2 text-center md:text-left">2x</div>
                <p class="text-xs sm:text-sm md:text-base text-lp-gray px-0 text-left">the Passport revenue compared to the PBS</p>
            </div>
        </div>
    </div>
</section>
{{/foreach}}
{{/get}}
