<section class="bg-lp-light-blue py-8 sm:py-12 md:py-16 lg:py-20 md:pt-[120px]">
    {{! PBS Station Logos }}
    <div class="max-w-6xl mx-auto px-4 sm:px-6 mt-6 sm:mt-8 md:mt-12 lg:mt-[120px] relative z-10">
        <div class="swiper swiper-pbs-stations">
            <div class="swiper-wrapper">
                {{#get "pages" limit="1" filter="tag:hash-pbs-stations"}}
                    {{#foreach pages}}
                        <div class="swiper-slide-temp">
                            {{content}}
                        </div>
                    {{/foreach}}
                {{/get}}
            </div>
        </div>
    </div>
</section>

