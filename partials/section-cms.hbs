{{#get "pages" limit="1" filter="tag:hash-cms"}}
    {{#foreach pages}}  
{{! CMS Section }}
<section class="bg-lp-light-blue py-8 sm:py-12 md:py-16 lg:py-20">
    <div class="container mx-auto px-4 sm:px-6">
        <div class="max-w-6xl mx-auto">
            <h2 class="text-[28px] sm:text-[32px] md:text-[40px] font-bold mb-3 sm:mb-4 text-center leading-[120%] sm:leading-[130%] md:leading-[52px] px-2 max-w-[600px] mx-auto">
                {{title}}
            </h2>
            <p class="text-[16px] sm:text-[18px] md:text-[20px] font-medium text-center mb-8 sm:mb-10 md:mb-12 max-w-3xl mx-auto leading-[24px] sm:leading-[26px] md:leading-[28px] px-2">
                {{excerpt}}
            </p>
            <div class="grid md:grid-cols-2 gap-6 sm:gap-8 md:gap-10 lg:gap-12 items-center">
                <div class="order-2 md:order-1">
                    {{content}}
                    <h3 class="text-[20px] sm:text-[22px] md:text-[24px] font-bold mb-2 leading-[28px] sm:leading-[30px] md:leading-[32px] hidden">{{title}}</h3>
                    <ul class="space-y-3 sm:space-y-2 text-sm sm:text-base md:text-[18px] lg:text-[20px] text-lp-gray hidden">
                        <li class="flex items-start">
                            <span class="mr-3 shrink-0">•</span>
                            <span></span>
                        </li>
                    </ul>
                </div>
                <div class="order-1 md:order-2">
                    <img src="{{asset "img/public.png"}}" alt="Public CMS Interface" class="w-full h-full object-cover">
                </div>
            </div>
        </div>
    </div>
</section>
{{/foreach}}
{{/get}}
