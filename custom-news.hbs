{{!< default}}

{{#page}}

{{! Header }}
<section class="bg-lp-light-blue py-4 sm:py-12 md:py-8">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
        <div class="max-w-4xl mx-auto text-center">
            <h1 class="text-[28px] sm:text-[36px] md:text-[40px] lg:text-[48px] font-extrabold mb-1 sm:mb-4 leading-[120%] text-lp-dark-blue">
                {{title}}
            </h1>
            {{#if custom_excerpt}}
                <p class="text-[16px] sm:text-[18px] md:text-[20px] font-medium text-lp-gray leading-[24px] sm:leading-[26px] md:leading-[28px] max-w-3xl mx-auto">
                    {{custom_excerpt}}
                </p>
            {{else}}
                <p class="text-[16px] sm:text-[18px] md:text-[20px] font-medium text-lp-gray leading-[24px] sm:leading-[26px] md:leading-[28px]">
                    Browse the complete archive
                </p>
            {{/if}}
        </div>
    </div>
</section>

{{! Optional page content (only if the author wrote some intro) }}
{{#if content}}
    <section class="bg-lp-light-blue pb-4 sm:pb-8">
        <div class="max-w-3xl mx-auto px-4 sm:px-6">
            <div class="ghost-content prose prose-lp max-w-none text-center">
                {{content}}
            </div>
        </div>
    </section>
{{/if}}

{{! All posts grid }}
<section class="bg-lp-light-blue py-4 sm:py-12 md:py-8">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
        {{#get "posts" limit="all" include="tags,authors" order="published_at desc"}}
            {{#if posts}}
                <p class="mb-6 sm:mb-8 text-sm text-lp-gray text-center">
                    {{plural pagination.total empty='No posts yet' singular='% post' plural='% posts'}}
                </p>
                <div class="grid sm:grid-cols-2 md:grid-cols-3 gap-6 sm:gap-8">
                    {{#foreach posts}}
                        {{> "card"}}
                    {{/foreach}}
                </div>
            {{else}}
                <div class="max-w-2xl mx-auto text-center py-8 sm:py-12">
                    <p class="text-lg sm:text-xl text-lp-gray mb-4">No posts found.</p>
                    <a href="{{@site.url}}" class="inline-block bg-lp-dark-blue text-white px-6 py-3 rounded-lg hover:opacity-90 transition-opacity">
                        Return to Home
                    </a>
                </div>
            {{/if}}
        {{/get}}
    </div>
</section>

{{/page}}
