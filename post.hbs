{{!< default}}
{{!-- The tag above means: insert everything in this file into the body of the default.hbs template --}}

{{#post}}

<main class="gh-main">

    <article class="ghost-post {{post_class}}">

        {{! Hero Header Section with Featured Image }}
        <header class="bg-lp-dark-blue text-white relative pb-6 sm:pb-8 md:pb-10 post-hero-border">
            <div class="max-w-6xl mx-auto px-4 sm:px-6 md:px-6 pt-6 sm:pt-6 md:pt-4 pb-4 sm:pb-6">
                <div>
                    {{#if feature_image}}
                        <div class="grid md:grid-cols-2 gap-6 sm:gap-8 md:gap-12 items-center">
                            <div>
                                {{#if primary_tag}}
                                    <div class="mb-3 sm:mb-4">
                                        <a href="{{primary_tag.url}}" class="inline-block px-3 sm:px-4 py-1.5 sm:py-2 bg-white/20 backdrop-blur-sm rounded-full text-xs sm:text-sm font-medium hover:bg-white/30 transition">
                                            {{primary_tag.name}}
                                        </a>
                                    </div>
                                {{/if}}
                                <h1 class="text-[24px] sm:text-[28px] md:text-[32px] lg:text-[36px] xl:text-[40px] font-extrabold mb-2 sm:mb-3 md:mb-4 leading-[110%] text-white tracking-tight">
                                    {{title}}
                                </h1>
                                {{#if custom_excerpt}}
                                    <p class="text-[15px] sm:text-[16px] md:text-[18px] lg:text-[20px] font-medium mb-3 sm:mb-4 md:mb-6 leading-[22px] sm:leading-[24px] md:leading-[26px] lg:leading-[28px] text-gray-200">
                                        {{custom_excerpt}}
                                    </p>
                                {{/if}}
                                <div class="flex flex-wrap items-center gap-3 sm:gap-4 md:gap-6 text-xs sm:text-sm text-gray-200">
                                    {{#foreach authors}}
                                        <div class="flex items-center">
                                            {{#if profile_image}}
                                                <img class="w-8 h-8 sm:w-10 sm:h-10 rounded-full mr-2 sm:mr-3 border-2 border-white/30" src="{{img_url profile_image size="xs"}}" alt="{{name}}">
                                            {{/if}}
                                            <div>
                                                <a href="{{url}}" class="block font-medium text-white hover:underline">{{name}}</a>
                                            </div>
                                        </div>
                                    {{/foreach}}
                                    <div class="flex items-center">
                                        <time datetime="{{date format="YYYY-MM-DD"}}" class="text-white font-medium">
                                            {{date format="MMMM D, YYYY"}}
                                        </time>
                                        {{#if reading_time}}
                                            <span class="text-gray-300 mx-2">—</span>
                                            <span class="text-gray-300">{{reading_time}}</span>
                                        {{/if}}
                                    </div>
                                </div>
                            </div>
                            <div class="order-first md:order-first">
                                <img class="w-full rounded-2xl shadow-2xl" src="{{img_url feature_image size="xl"}}" alt="{{title}}">
                            </div>
                        </div>
                    {{else}}
                        <div class="w-full sm:max-w-4xl mx-auto">
                            {{#if primary_tag}}
                                <div class="mb-3 sm:mb-4">
                                    <a href="{{primary_tag.url}}" class="inline-block px-3 sm:px-4 py-1.5 sm:py-2 bg-white/20 backdrop-blur-sm rounded-full text-xs sm:text-sm font-medium hover:bg-white/30 transition">
                                        {{primary_tag.name}}
                                    </a>
                                </div>
                            {{/if}}
                            <h1 class="text-[24px] sm:text-[28px] md:text-[32px] lg:text-[36px] xl:text-[40px] font-extrabold mb-2 sm:mb-3 md:mb-4 leading-[110%] text-white tracking-tight">
                                {{title}}
                            </h1>
                            {{#if custom_excerpt}}
                                <p class="text-[15px] sm:text-[16px] md:text-[18px] lg:text-[20px] font-medium mb-3 sm:mb-4 md:mb-6 leading-[22px] sm:leading-[24px] md:leading-[26px] lg:leading-[28px] text-gray-200">
                                    {{custom_excerpt}}
                                </p>
                            {{/if}}
                            <div class="flex flex-wrap items-center gap-3 sm:gap-4 md:gap-6 text-xs sm:text-sm text-gray-200">
                                {{#foreach authors}}
                                    <div class="flex items-center">
                                        {{#if profile_image}}
                                            <img class="w-8 h-8 sm:w-10 sm:h-10 rounded-full mr-2 sm:mr-3 border-2 border-white/30" src="{{img_url profile_image size="xs"}}" alt="{{name}}">
                                        {{/if}}
                                        <div>
                                            <a href="{{url}}" class="block font-medium text-white hover:underline">{{name}}</a>
                                        </div>
                                    </div>
                                {{/foreach}}
                                <div class="flex items-center">
                                    <time datetime="{{date format="YYYY-MM-DD"}}" class="text-white font-medium">
                                        {{date format="MMMM D, YYYY"}}
                                    </time>
                                    {{#if reading_time}}
                                        <span class="text-gray-300 mx-2">—</span>
                                        <span class="text-gray-300">{{reading_time}}</span>
                                    {{/if}}
                                </div>
                            </div>
                        </div>
                    {{/if}}
                </div>
            </div>
        </header>

        {{! Content Section }}
        <section class="bg-lp-light-blue py-6 sm:py-8 md:py-12 lg:py-16 lg:pb-8 xl:pb-8 ">
            <div class="w-full px-4 sm:px-6 md:container mx-auto">
                <div class="w-full sm:max-w-4xl mx-auto">
                    <div class="ghost-content prose prose-lg prose-lp max-w-none prose-mobile">
                        {{content}}
                    </div>
                </div>
            </div>
        </section>

        {{! Author Box Section }}
        {{#foreach authors}}
            <section class="bg-lp-light-blue pt-4 sm:pt-6 pb-6 sm:pb-8 md:pb-12 lg:pb-16 xl:pb-20">
                <div class="w-full px-4 sm:px-6 md:container mx-auto">
                    <div class="w-full sm:max-w-4xl mx-auto">
                        <div class="bg-white rounded-xl sm:rounded-2xl border-2 p-4 sm:p-6 md:p-8 lg:p-10" style="border-color: rgba(46, 48, 145, 0.24);">
                            <div class="flex flex-col sm:flex-row items-start sm:items-center gap-4 sm:gap-6">
                                {{#if profile_image}}
                                    <div class="shrink-0">
                                        <a href="{{url}}">
                                            <img class="w-20 h-20 sm:w-24 sm:h-24 rounded-full border-4 border-lp-light-blue" src="{{img_url profile_image size="m"}}" alt="{{name}}">
                                        </a>
                                    </div>
                                {{/if}}
                                <div class="flex-1">
                                    <div class="mb-1.5 sm:mb-2">
                                        <span class="text-xs sm:text-sm font-medium text-lp-gray uppercase tracking-wide">Written by</span>
                                    </div>
                                    <h3 class="text-[18px] sm:text-[20px] md:text-[22px] lg:text-[24px] font-bold text-lp-dark-blue mb-2 sm:mb-3 leading-[26px] sm:leading-[28px] md:leading-[30px] lg:leading-[32px]">
                                        <a href="{{url}}" class="hover:underline">{{name}}</a>
                                    </h3>
                                    {{#if bio}}
                                        <p class="text-[13px] sm:text-[14px] md:text-[15px] lg:text-[16px] font-medium text-lp-gray leading-[20px] sm:leading-[22px] md:leading-[23px] lg:leading-[24px] mb-2 sm:mb-3 md:mb-4">
                                            {{bio}}
                                        </p>
                                    {{/if}}
                                    <div class="flex flex-wrap gap-3 sm:gap-4 text-xs sm:text-sm text-lp-gray">
                                        {{#if location}}
                                            <div class="flex items-center">
                                                <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                                                </svg>
                                                {{location}}
                                            </div>
                                        {{/if}}
                                        {{#if website}}
                                            <a href="{{website}}" target="_blank" rel="noopener" class="flex items-center text-lp-dark-blue hover:underline">
                                                <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"/>
                                                </svg>
                                                Website
                                            </a>
                                        {{/if}}
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </section>
        {{/foreach}}

    </article>

    {{#if @site.comments_enabled}}
        <div class="bg-lp-light-blue py-6 sm:py-8 md:py-10 lg:py-12">
            <div class="w-full px-4 sm:px-6 md:container mx-auto">
                <div class="w-full sm:max-w-4xl mx-auto">
                    <div class="gh-comments">
                        {{comments}}
                    </div>
                </div>
            </div>
        </div>
    {{/if}}

</main>

{{/post}}