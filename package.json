{
  "name": "localpublic-news",
  "description": "Local Public Ghost Theme (with News archive page and header cleanup)",
  "version": "1.0.0",
  "engines": {
    "ghost": ">=5.0.0"
  },
  "type": "module",
  "author": {
    "name": "Local Public",
    "email": "info@localpublic.com",
    "url": "https://localpublic.com"
  },
  "gpm": {
    "type": "theme",
    "categories": [
      "Blog"
    ]
  },
  "keywords": [
    "ghost",
    "theme",
    "ghost-theme"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/localpublic/localpublic.git"
  },
  "scripts": {
    "dev": "vite build --watch & vite",
    "serve": "vite",
    "watch": "vite build --watch",
    "prebuild": "node theme.js",
    "build": "vite build",
    "preview": "vite preview",
    "test": "gscan . --verbose",
    "zip": "npm run build && npm run test && mkdir -p dist && zip -r dist/${npm_package_name} . -x 'dist*' 'demo*' 'node_modules*' '.*' 'TODO.md' 'private.hbs'",
    "release": "npm version minor --no-git-tag-version && git add . && git commit -m \"v$(node -p 'require(\"./package.json\").version')\" && git push && npm run zip"
  },
  "dependencies": {
    "@tailwindcss/forms": "^0.5.10",
    "@tailwindcss/typography": "^0.5.16",
    "@tailwindcss/vite": "^4.0.15",
    "@tryghost/content-api": "^1.11.21",
    "@vitejs/plugin-legacy": "^5.4.3",
    "alpinejs": "^3.14.9",
    "fitvids": "^2.1.1",
    "gscan": "^5.0.0",
    "swiper": "^12.0.3",
    "tailwindcss": "^4.0.0",
    "tocbot": "^4.35.3",
    "vite": "^5.4.15"
  },
  "config": {
    "card_assets": true,
    "posts_per_page": 12,
    "image_sizes": {
      "xxs": {
        "width": 30
      },
      "xs": {
        "width": 100
      },
      "s": {
        "width": 320
      },
      "m": {
        "width": 640
      },
      "l": {
        "width": 960
      },
      "xl": {
        "width": 1280
      },
      "xxl": {
        "width": 2000
      }
    },
    "custom": {
      "hero_title": {
        "type": "text",
        "default": "Public Media Streaming Made Simple",
        "description": "Hero section main heading"
      },
      "hero_description": {
        "type": "text",
        "default": "Local Public empowers stations to collaborate, curate, and deliver their on-demand and live content everywhere it matters.",
        "description": "Hero section description text"
      },
      "hero_button_text": {
        "type": "text",
        "default": "Book a demo",
        "description": "Hero section primary button text"
      },
      "hero_button_url": {
        "type": "text",
        "default": "#contact",
        "description": "Hero section primary button URL"
      }
    }
  }
}
